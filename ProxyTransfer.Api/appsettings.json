{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "ApiKey": "change-me"
  },
  "TunnelHost": {
    "ManagementUrl": "http://127.0.0.1:5081",
    "ManagementApiKey": "change-me",
    "ListenAddress": "0.0.0.0",
    "PublicHost": "127.0.0.1",
    "ApiUrl": "http://0.0.0.0:5080",
    "DefaultStickyMinutes": 10,
    "FailureCooldownSeconds": 90,
    "ProbeIntervalSeconds": 60,
    "ProbeTimeoutSeconds": 10,
    "ProbeTargetHost": "example.com",
    "ProbeTargetPort": 443,
    "TestHistoryFilePath": "App_Data/test-history.json",
    "UpstreamPoolStateFilePath": "App_Data/upstream-pools.json",
    "UpstreamPoolTestHistoryFilePath": "App_Data/upstream-pool-test-history.json",
    "DefaultTestProvider": "ifconfig"
  },
  "Cors": {
    "AllowedOrigins": []
  }
}